DATABASE_URL="postgresql://postgres:postgres@localhost:5432/german_smart_apply?schema=public"

# TODO: swap for Clerk/NextAuth when API keys are available. Until then this
# signs/verifies the dev-mode local email+password JWTs (see src/auth).
JWT_SECRET="change-me-in-production"

PORT=3001

# TODO: Phase-later — move to S3-compatible object storage per plan.md's
# stack table. Local disk is a fine stand-in for dev/sandbox.
CV_UPLOAD_DIR="./uploads/cv"

# Base URL of the frontend, used to build Stripe checkout/portal redirect
# links (billing.service.ts).
WEB_APP_URL="http://localhost:3100"

# All three below are required together to enable the real StripeBillingProvider;
# leave any one unset (as in this sandbox) and BillingService falls back to
# MockBillingProvider automatically - no code change needed once real keys exist.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRO_PRICE_ID=""

# Leave both unset to run with the deterministic MockAiProvider. If
# OPENROUTER_API_KEY is set, createAiProvider() prefers it over
# ANTHROPIC_API_KEY - a cheap way to smoke-test real-model behavior on a
# free-tier model (openrouter.ai) before committing to Anthropic's paid API.
# OPENROUTER_MODEL overrides the default free model slug.
ANTHROPIC_API_KEY=""
OPENROUTER_API_KEY=""
OPENROUTER_MODEL=""

# TEMPORARY diagnostic (see packages/ai/src/match-score-estimate.ts): when
# "true", the job detail page appends a second, blind model-judged match
# percentage to the match explanation, for comparing against our
# deterministic ranking score. Adds one extra strong-tier model call per
# job-detail view and only produces a real number against a real provider
# (Anthropic/OpenRouter) - MockAiProvider doesn't implement it. Leave unset
# in production.
MATCH_SCORE_DIAGNOSTIC_ENABLED=""
