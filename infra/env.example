# Consolidated reference of every env var used across docker-compose.yml's
# services. Copy to infra/.env before running `docker compose up` if you
# want to override any default (compose reads infra/.env automatically).
# Per-app .env.example files (apps/api/.env.example, packages/db/.env.example)
# are the source of truth for local (non-Docker) dev.

# --- api ---
JWT_SECRET=change-me-in-production

# Leave all three unset to run with MockBillingProvider (no real Stripe
# account needed for local dev/CI). Compose doesn't set NODE_ENV=production,
# so this fallback is available here - but the app refuses to start this way
# whenever NODE_ENV=production (see billing.service.ts's createBillingProvider).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

# Leave unset to run with the deterministic MockAiProvider (no Anthropic
# account needed for local dev/CI).
ANTHROPIC_API_KEY=
