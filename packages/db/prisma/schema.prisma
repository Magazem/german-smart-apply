generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Sources domain
// ─────────────────────────────────────────────────────────────

enum TrustTier {
  high
  medium
  low
}

model Source {
  id                    String    @id @default(uuid())
  sourceType            String
  displayName           String
  countryCode           String
  trustTier             TrustTier @default(medium)
  crawlFrequencyMinutes Int       @default(360)
  config                Json      @default("{}")
  domainAllowlist       String[]  @default([])
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  crawlRuns    SourceCrawlRun[]
  rawSnapshots RawJobSnapshot[]
  rawJobs      RawJob[]

  @@index([countryCode])
  @@map("sources")
}

enum CrawlRunStatus {
  running
  success
  partial_failure
  failure
}

model SourceCrawlRun {
  id          String         @id @default(uuid())
  sourceId    String
  source      Source         @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  status      CrawlRunStatus @default(running)
  startedAt   DateTime       @default(now())
  finishedAt  DateTime?
  jobsFetched Int            @default(0)
  jobsNew     Int            @default(0)
  jobsUpdated Int            @default(0)
  errorLog    String?
  retryCount  Int            @default(0)

  @@index([sourceId, startedAt])
  @@map("source_crawl_runs")
}

model RawJobSnapshot {
  id            String   @id @default(uuid())
  sourceId      String
  source        Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  originalJobId String
  payload       Json
  fetchedAt     DateTime @default(now())

  @@index([sourceId, originalJobId])
  @@map("raw_job_snapshots")
}

// ─────────────────────────────────────────────────────────────
// Jobs domain
// ─────────────────────────────────────────────────────────────

model RawJob {
  id                    String    @id @default(uuid())
  sourceId              String
  source                Source    @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  originalJobId         String
  sourceUrl             String
  companyNameRaw        String
  companyNameNormalized String
  jobTitleRaw           String
  jobTitleNormalized    String
  jobDescriptionHtml    String?
  jobDescriptionText    String
  language              String
  locationRaw           String
  locationNormalized    String
  countryCode           String
  remoteType            String
  employmentType        String
  seniority             String?
  salaryMin             Int?
  salaryMax             Int?
  salaryCurrency        String?
  techStackTags         String[]  @default([])
  applyUrl              String
  postedAt              DateTime?
  crawledAt             DateTime  @default(now())
  sourceTrustScore      Float     @default(0.5)
  scamRiskScore         Float     @default(0)
  isDeduplicated        Boolean   @default(false)

  canonicalJob       CanonicalJob?
  clusterMemberships DuplicateClusterMember[]

  @@unique([sourceId, originalJobId])
  @@index([companyNameNormalized, jobTitleNormalized, locationNormalized])
  @@map("raw_jobs")
}

model CanonicalJob {
  id                    String    @id @default(uuid())
  rawJobId              String    @unique
  rawJob                RawJob    @relation(fields: [rawJobId], references: [id], onDelete: Cascade)
  companyNameNormalized String
  jobTitleNormalized    String
  locationNormalized    String
  countryCode           String
  remoteType            String
  employmentType        String
  seniority             String?
  salaryMin             Int?
  salaryMax             Int?
  salaryCurrency        String?
  techStackTags         String[]  @default([])
  language              String
  sourceTrustScore      Float
  scamRiskScore         Float
  duplicateConfidence   Float     @default(1.0)
  postedAt              DateTime?
  crawledAt             DateTime
  isVisible             Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  clusters     DuplicateCluster[]
  savedByUsers SavedJob[]
  interactions JobInteraction[]
  applications Application[]

  @@index([countryCode, jobTitleNormalized])
  @@index([companyNameNormalized])
  @@map("canonical_jobs")
}

model DuplicateCluster {
  id             String       @id @default(uuid())
  canonicalJobId String
  canonicalJob   CanonicalJob @relation(fields: [canonicalJobId], references: [id], onDelete: Cascade)
  clusterKey     String
  createdAt      DateTime     @default(now())

  members DuplicateClusterMember[]

  @@index([clusterKey])
  @@map("duplicate_clusters")
}

model DuplicateClusterMember {
  id                 String           @id @default(uuid())
  duplicateClusterId String
  duplicateCluster   DuplicateCluster @relation(fields: [duplicateClusterId], references: [id], onDelete: Cascade)
  rawJobId           String
  rawJob             RawJob           @relation(fields: [rawJobId], references: [id], onDelete: Cascade)
  similarityScore    Float
  isCanonicalPick    Boolean          @default(false)
  createdAt          DateTime         @default(now())

  @@unique([duplicateClusterId, rawJobId])
  @@map("duplicate_cluster_members")
}

model CompanyAlias {
  id                    String   @id @default(uuid())
  companyNameNormalized String
  alias                 String
  aliasType             String   @default("variant") // variant | abbreviation | legal_name | brand
  createdAt             DateTime @default(now())

  @@unique([companyNameNormalized, alias])
  @@index([alias])
  @@map("company_aliases")
}

// ─────────────────────────────────────────────────────────────
// Users domain
// ─────────────────────────────────────────────────────────────

enum SubscriptionStatus {
  free
  pro
  canceled
  past_due
}

enum UserRole {
  user
  admin
}

model User {
  id                   String             @id @default(uuid())
  email                String             @unique
  authProviderId       String?            @unique
  // Dev-mode local email+password auth stand-in.
  // TODO: swap for Clerk/NextAuth when API keys are available; this column
  // becomes unused once authProviderId-based auth takes over.
  passwordHash         String?
  subscriptionStatus   SubscriptionStatus @default(free)
  // No self-serve path to become admin, same as there's no self-serve path
  // to bypass Stripe for Pro - promote via a manual DB update (documented in
  // DEPLOYMENT.md) rather than exposing any in-app role switch.
  role                 UserRole           @default(user)
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  candidateProfile CandidateProfile?
  cvDocuments      CvDocument[]
  savedJobs        SavedJob[]
  interactions     JobInteraction[]
  applications     Application[]
  savedSearches    SavedSearch[]
  tokenUsageEvents TokenUsageEvent[]
  consentRecords   ConsentRecord[]
  roleGapAnalyses  RoleGapAnalysis[]

  @@map("users")
}

model CandidateProfile {
  id                  String   @id @default(uuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName            String?
  email               String?
  phone               String?
  targetRole          String
  targetCountryCode   String   @default("DE")
  preferredLanguage   String   @default("en")
  seniority           String
  locationPreference  String   @default("any")
  skills              String[] @default([])
  summary             String?
  // JSON, not a related table: same shape as ParsedCvExperience/
  // ParsedCvEducation in packages/shared - a straight copy from CV-parse
  // output, not independently queried/filtered today. Revisit as proper
  // relational tables if the product later needs e.g. "years of experience"
  // calculations at the DB layer.
  experience          Json     @default("[]")
  education           Json     @default("[]")
  languages           String[] @default([])
  salaryTargetMin     Int?
  salaryTargetMax     Int?
  workAuthorization   String?
  companyBlacklist    String[] @default([])
  // Where the candidate is and where they'd work, as distinct from
  // locationPreference (a work MODE only). Nullable/empty by default so
  // existing profiles keep scoring exactly as before until they fill these
  // in - see market-de's cityFit(), which returns 'unknown' in that case.
  // relocationWillingness is a string, not an enum, matching how
  // locationPreference and seniority are already stored; the allowed values
  // live in shared's RELOCATION_WILLINGNESS.
  homeCity            String?
  acceptableCities    String[] @default([])
  relocationWillingness String?
  commutePreferenceKm Int?
  portfolioLinks      String[] @default([])
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("candidate_profiles")
}

model CvDocument {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName     String
  storageKey   String
  mimeType     String
  parsedResult Json?
  parseStatus  String   @default("pending") // pending | parsed | failed
  createdAt    DateTime @default(now())

  @@index([userId])
  @@map("cv_documents")
}

model SavedJob {
  id             String       @id @default(uuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  canonicalJobId String
  canonicalJob   CanonicalJob @relation(fields: [canonicalJobId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([userId, canonicalJobId])
  @@map("saved_jobs")
}

enum InteractionType {
  view
  like
  skip
  share
}

model JobInteraction {
  id              String          @id @default(uuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  canonicalJobId  String
  canonicalJob    CanonicalJob    @relation(fields: [canonicalJobId], references: [id], onDelete: Cascade)
  interactionType InteractionType
  createdAt       DateTime        @default(now())

  @@index([userId, canonicalJobId])
  @@map("job_interactions")
}

// ─────────────────────────────────────────────────────────────
// Applications domain
// ─────────────────────────────────────────────────────────────

enum ApplicationStatus {
  new
  viewed
  saved
  draft_ready
  awaiting_approval
  applied
  interview
  rejected
  offer
  archived
}

model Application {
  id             String            @id @default(uuid())
  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  canonicalJobId String
  canonicalJob   CanonicalJob      @relation(fields: [canonicalJobId], references: [id], onDelete: Cascade)
  status         ApplicationStatus @default(new)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  drafts        ApplicationDraft[]
  events        ApplicationEvent[]
  followUps     FollowUpDraft[]
  interviewPrep InterviewPrepDraft[]

  @@unique([userId, canonicalJobId])
  @@index([userId, status])
  @@map("applications")
}

model ApplicationDraft {
  id              String      @id @default(uuid())
  applicationId   String
  application     Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  cvVariantText   String
  coverLetterText String
  // 'standard' | 'concise' | 'leadership' - see CV_VARIANT_STYLES in
  // packages/shared. Defaulted for existing rows predating this column;
  // 'standard' is also the only style free-tier users can generate
  // (ApplicationsService.generateDraft enforces Pro for the others).
  variantLabel    String      @default("standard")
  modelUsed       String
  tokensUsed      Int         @default(0)
  createdAt       DateTime    @default(now())

  @@index([applicationId])
  @@map("application_drafts")
}

model FollowUpDraft {
  id            String      @id @default(uuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  subject       String
  body          String
  modelUsed     String
  tokensUsed    Int         @default(0)
  createdAt     DateTime    @default(now())

  @@index([applicationId])
  @@map("follow_up_drafts")
}

model InterviewPrepDraft {
  id            String      @id @default(uuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  questions     String[]    @default([])
  talkingPoints String[]    @default([])
  modelUsed     String
  tokensUsed    Int         @default(0)
  createdAt     DateTime    @default(now())

  @@index([applicationId])
  @@map("interview_prep_drafts")
}

model ApplicationEvent {
  id            String             @id @default(uuid())
  applicationId String
  application   Application        @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  fromStatus    ApplicationStatus?
  toStatus      ApplicationStatus
  note          String?
  createdAt     DateTime           @default(now())

  @@index([applicationId])
  @@map("application_events")
}

// ─────────────────────────────────────────────────────────────
// Alerts domain
// ─────────────────────────────────────────────────────────────

model SavedSearch {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  filters   Json
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deliveries AlertDelivery[]

  @@index([userId])
  @@map("saved_searches")
}

model AlertDelivery {
  id            String      @id @default(uuid())
  savedSearchId String
  savedSearch   SavedSearch @relation(fields: [savedSearchId], references: [id], onDelete: Cascade)
  jobIds        String[]
  channel       String      @default("email")
  sentAt        DateTime    @default(now())

  @@index([savedSearchId])
  @@map("alert_deliveries")
}

// ─────────────────────────────────────────────────────────────
// Usage tracking domain
// ─────────────────────────────────────────────────────────────

// One row per AI-provider call that used real tokens - an append-only log,
// not a running total, so it can be aggregated per user AND per feature
// (plan.md's "Token usage tracking per user and feature") without losing
// the ability to inspect individual calls later. ApplicationDraft already
// stores its own tokensUsed for the drafting UI's own purposes; this table
// exists for cross-feature usage reporting, not to replace that.
model TokenUsageEvent {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  feature    String
  modelUsed  String
  tokensUsed Int
  createdAt  DateTime @default(now())

  @@index([userId, feature])
  @@map("token_usage_events")
}

enum ConsentType {
  terms
  privacy
  marketing
}

// Append-only consent log (never updated/deleted) so we can always prove what
// a user agreed to and when, even after the policy text is later revised -
// a mutable "accepted: true" flag on User can't demonstrate that.
model ConsentRecord {
  id            String      @id @default(uuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  consentType   ConsentType
  policyVersion String
  acceptedAt    DateTime    @default(now())

  @@index([userId, consentType])
  @@map("consent_records")
}

// ─────────────────────────────────────────────────────────────
// Career coach domain
// ─────────────────────────────────────────────────────────────

// Persisted (not regenerated on every view) since a run costs real AI tokens
// and users will want to revisit past analyses to see how their skills have
// progressed - same rationale as ApplicationDraft.
model RoleGapAnalysis {
  id                        String   @id @default(uuid())
  userId                    String
  user                      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetRole                String
  matchingSkills            String[] @default([])
  missingSkills             String[] @default([])
  suggestedLearningTopics   String[] @default([])
  suggestedCertifications   String[] @default([])
  estimatedReadinessScore   Int
  summary                   String
  sampleJobCount            Int      @default(0)
  modelUsed                 String
  tokensUsed                Int      @default(0)
  createdAt                 DateTime @default(now())

  @@index([userId, createdAt])
  @@map("role_gap_analyses")
}

// ─────────────────────────────────────────────────────────────
// App-wide runtime settings
// ─────────────────────────────────────────────────────────────

// Generic key/value store for admin-editable settings that should take
// effect immediately (no redeploy/env var change) - e.g. an OpenRouter
// model override for A/B testing free vs. paid models. Deliberately a flat
// key/value table rather than one dedicated column/table per setting, so
// adding a new runtime-editable setting later doesn't need its own
// migration. See apps/api/src/ai/ai-provider-factory.service.ts for the
// first consumer.
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}
